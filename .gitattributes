# Keep LF line endings everywhere (this site deploys to a Linux server).
# Text files are normalized to LF in the repo AND in the working copy.
* text=auto eol=lf

# Binary assets - never modify
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.pdf   binary
